<OnlineJoinScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 16
        Label:
            id: title_label
            text: "Join a Game"
            font_size: 36
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.13
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: subtitle_label
            text: "Enter the 4-digit game code:"
            font_size: 16
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.07
        Label:
            id: code_input_display
            text: "____"
            font_size: 56
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFD700")
            size_hint_y: 0.16
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: join_error_label
            text: ""
            font_size: 14
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFD700")
            size_hint_y: 0.06
        GridLayout:
            cols: 3
            spacing: 8
            size_hint_y: 0.28
            padding: [20, 0]
            Button:
                text: "1"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("1")
            Button:
                text: "2"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("2")
            Button:
                text: "3"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("3")
            Button:
                text: "4"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("4")
            Button:
                text: "5"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("5")
            Button:
                text: "6"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("6")
            Button:
                text: "7"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("7")
            Button:
                text: "8"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("8")
            Button:
                text: "9"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("9")
            Button:
                text: "X"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#BF360C")
                background_normal: ""
                on_press: root.on_backspace()
            Button:
                text: "0"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#558B2F")
                background_normal: ""
                on_press: root.on_digit("0")
            Button:
                text: "V"
                font_name: "NotoHebrewBold"
                font_size: 28
                background_color: get_color_from_hex("#1B5E20")
                background_normal: ""
                on_press: root.on_join()
        Button:
            id: back_btn
            text: "Back"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.08
            background_color: get_color_from_hex("#8D6E63")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.manager.current = "online_menu"
        Label:
            size_hint_y: 0.06

<OnlineGameScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
