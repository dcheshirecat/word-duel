        ScrollView:
            size_hint_y: 0.55
            do_scroll_x: False
            do_scroll_y: True
            GridLayout:
                id: tile_grid
                cols: 5
                rows: 6
                spacing: 6
                size_hint_y: None
                row_default_height: 56
                height: self.minimum_height
                padding: [20, 4]
        BoxLayout:
            id: keyboard_area
            orientation: "vertical"
            size_hint_y: 0.31
            spacing: 6
            orientation: "vertical"
            size_hint_y: 0.31
            spacing: 6
            id: keyboard_area
            orientation: "vertical"
            size_hint_y: 0.36
            spacing: 6

<RulesScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
