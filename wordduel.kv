#:import get_color_from_hex kivy.utils.get_color_from_hex

<MenuScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 12
        Label:
            text: "The Word Game"
            font_size: 42
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.18
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            text: "\u05dd\u05d9\u05dc\u05d9\u05de\u05d4 \u05e7\u05d7\u05e9\u05de"
            font_size: 38
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#F3E8FF")
            size_hint_y: 0.14
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            text: "Choose your language"
            font_size: 16
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.07
        Button:
            text: "Play in English"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.13
            background_color: get_color_from_hex("#F9A825")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press:
                root.manager.get_screen("mode_screen").set_language("en")
                root.manager.current = "mode_screen"
        Button:
            text: "\u05ea\u05d9\u05e8\u05d1\u05e2\u05d1 \u05e7\u05d7\u05e9"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.13
            background_color: get_color_from_hex("#558B2F")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press:
                root.manager.get_screen("mode_screen").set_language("he")
                root.manager.current = "mode_screen"
        Label:
            size_hint_y: 0.35

<ModeScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 16
        Label:
            id: title_label
            text: "The Word Game"
            font_size: 42
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.2
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: subtitle_label
            text: "Choose your mode"
            font_size: 28
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.08
        Button:
            id: single_btn
            text: "Single Player"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.1
            background_color: get_color_from_hex("#1B5E20")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.choose_mode("single")
        Button:
            id: multi_btn
            text: "Pass & Play"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.1
            background_color: get_color_from_hex("#558B2F")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.choose_mode("multi")
        Button:
            id: online_btn
            text: "Play Online"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.1
            background_color: get_color_from_hex("#F57F17")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.go_online()
        Button:
            id: rules_btn
            text: "Rules"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.09
            background_color: get_color_from_hex("#1B5E20")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.go_rules()
        Button:
            id: back_btn
            text: "Back"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.09
            background_color: get_color_from_hex("#8D6E63")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.manager.current = "menu"
        Label:
            size_hint_y: 0.14

<WordSetterScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 12
        Label:
            id: title_label
            text: "Player 1"
            font_size: 36
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.1
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: subtitle_label
            text: "Type your secret word"
            font_size: 16
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.07
        Label:
            id: hidden_display
            text: "_ _ _ _ _"
            font_size: 36
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.1
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: error_label
            text: ""
            font_size: 14
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFD700")
            size_hint_y: 0.06
        Button:
            id: back_btn
            text: "Back"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.07
            background_color: get_color_from_hex("#8D6E63")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.manager.current = "mode_screen"
        BoxLayout:
            id: setter_keyboard
            orientation: "vertical"
            size_hint_y: 0.6
            spacing: 6

<PassPhoneScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 24
        Label:
            id: title_label
            text: "Pass the phone!"
            font_size: 38
            bold: True
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            size_hint_y: 0.25
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.35
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
        Label:
            id: instruction_label
            text: "Hand the phone to Player 2."
            font_size: 17
            font_name: "NotoHebrewBold"
            color: get_color_from_hex("#FFFFFF")
            halign: "center"
            size_hint_y: 0.2
        Button:
            id: ready_btn
            text: "Player 2 is ready!"
            font_size: 34
            font_name: "NotoHebrewBold"
            size_hint_y: 0.15
            background_color: get_color_from_hex("#6AAF69")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.proceed_to_game()
        Button:
            id: back_btn
            text: "Back"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.1
            background_color: get_color_from_hex("#8D6E63")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.manager.current = "word_setter"
        Label:
            size_hint_y: 0.3

<GameScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: "dacha_bg.png"
    BoxLayout:
        orientation: "vertical"
        padding: [10, 10]
        spacing: 6
        BoxLayout:
            size_hint_y: 0.07
            spacing: 8
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.3
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
            Label:
                id: title_label
                text: "The Word Game"
                font_size: 20
                bold: True
                font_name: "NotoHebrewBold"
                color: get_color_from_hex("#FFFFFF")
            Label:
                id: message_label
                text: ""
                font_size: 14
                font_name: "NotoHebrewBold"
                color: get_color_from_hex("#FFD700")
            Button:
                id: menu_btn
                text: "Menu"
                font_size: 14
                font_name: "NotoHebrewBold"
                size_hint_x: 0.2
                background_color: get_color_from_hex("#8D6E63")
                background_normal: ""
                color: [1, 1, 1, 1]
                on_press: root.manager.current = "menu"
        ScrollView:
            size_hint_y: 0.55
            do_scroll_x: False
            do_scroll_y: True
            GridLayout:
                id: tile_grid
                cols: 5
                rows: 6
                spacing: 6
                size_hint_y: None
                row_default_height: 56
                height: self.minimum_height
                padding: [20, 4]
        BoxLayout:
            id: keyboard_area
            orientation: "vertical"
            size_hint_y: 0.31
            spacing: 6

<OnlineMenuScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
