                text: ""
                font_size: 18
                font_name: "NotoHebrewBold"
                color: get_color_from_hex("#FFFFFF")
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                halign: "left"
                valign: "top"
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 0.35
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
        Button:
            id: back_btn
            text: "Back"
            font_size: 28
            font_name: "NotoHebrewBold"
            size_hint_y: 0.12
            background_color: get_color_from_hex("#8D6E63")
            background_normal: ""
            color: [1, 1, 1, 1]
            on_press: root.manager.current = "mode_screen"
